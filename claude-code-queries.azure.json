    {
      "id": 105,
      "type": "timeseries",
      "title": "Daily active users (30d)",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${DS_AZURE_MONITOR}"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${DS_AZURE_MONITOR}"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "AppTraces\n| where TimeGenerated > ago(30d)\n| extend email = tostring(Properties['user.email'])\n| where isnotempty(email)\n| summarize DAU = dcount(email) by bin(TimeGenerated, 1d)\n| order by TimeGenerated asc\n",
            "resource": "$law_resource",
            "resultFormat": "time_series"
          },
          "refId": "A",
          "legendFormat": "DAU"
        }
      ]
    },
    {
      "id": 106,
      "type": "table",
      "title": "Users (last 7d)",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${DS_AZURE_MONITOR}"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${DS_AZURE_MONITOR}"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "AppTraces\n| where TimeGenerated > ago(7d)\n| extend email = tostring(Properties['user.email'])\n| where isnotempty(email)\n| summarize\n    events = count(),\n    sessions = dcount(tostring(Properties['session.id'])),\n    first_seen = min(TimeGenerated),\n    last_seen = max(TimeGenerated)\n  by email\n| order by events desc\n",
            "resource": "$law_resource",
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 107,
      "type": "table",
      "title": "Users by username (multi-account aggregation)",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${DS_AZURE_MONITOR}"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${DS_AZURE_MONITOR}"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "AppTraces\n| where TimeGenerated > ago(7d)\n| extend email = tostring(Properties['user.email'])\n| where isnotempty(email)\n| extend username = tostring(split(email, \"@\")[0])\n| summarize\n    accounts = make_set(email),\n    events = count(),\n    sessions = dcount(tostring(Properties['session.id']))\n  by username\n| order by events desc\n",
            "resource": "$law_resource",
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 108,
      "type": "table",
      "title": "Active hours per user (7d, prompt-active 1h buckets)",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${DS_AZURE_MONITOR}"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${DS_AZURE_MONITOR}"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "AppTraces\n| where TimeGenerated > ago(7d)\n| where tostring(Properties['event.name']) == \"user_prompt\"\n| extend email = tostring(Properties['user.email'])\n| extend hour_bucket = bin(TimeGenerated, 1h)\n| summarize prompts = count(), active_hours = count_distinct(hour_bucket) by email\n| order by active_hours desc\n",
            "resource": "$law_resource",
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ]
    },
    {
      "id": 109,
      "type": "barchart",
      "title": "Prompts by hour of day (30d)",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "${DS_AZURE_MONITOR}"
      },
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 9

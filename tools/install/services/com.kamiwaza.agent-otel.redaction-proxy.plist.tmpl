<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd LaunchAgent for the agent-otel redaction proxy.

  Lives at ~/Library/LaunchAgents/com.kamiwaza.agent-otel.redaction-proxy.plist
  after install.sh substitutes the {{...}} placeholders.

  Loaded with:
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.kamiwaza.agent-otel.redaction-proxy.plist

  KeepAlive=true: relaunch on crash + relaunch if killed unexpectedly.
  RunAtLoad=true: start when this user's session opens (login or `bootstrap`).
  ThrottleInterval=10: don't relaunch faster than once / 10s if the proxy
                       crash-loops — stops a runaway from saturating the
                       launchd process table.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kamiwaza.agent-otel.redaction-proxy</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{LAUNCHER}}</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>{{LOG_DIR}}/redaction-proxy.out.log</string>
    <key>StandardErrorPath</key>
    <string>{{LOG_DIR}}/redaction-proxy.err.log</string>

    <key>WorkingDirectory</key>
    <string>{{INSTALL_DIR}}</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>
